;// ═══ PetAgent:pet ═══
// 便携部署路径查找：在 hermes-agent 源码树中查找安装脚本
// 安全策略：如果 module.exports 中没有 resolveInstallScript，则不做任何事

;(function() {
  try {
    if (module.exports && typeof module.exports.resolveInstallScript === 'function') {
      var _origResolve = module.exports.resolveInstallScript;
      module.exports.resolveInstallScript = async function() {
        var hermesHome = process.env.HERMES_HOME;
        if (hermesHome) {
          var path = require('path');
          var fs = require('fs');
          var scriptName = process.platform === 'win32' ? 'install.ps1' : 'install.sh';
          var portableScript = path.join(hermesHome, 'hermes-agent', 'scripts', scriptName);
          try {
            await fs.promises.access(portableScript, fs.constants.R_OK);
            return { path: portableScript, source: 'portable', kind: process.platform === 'win32' ? 'ps1' : 'sh' };
          } catch(_) {}
        }
        return _origResolve.apply(this, arguments);
      };
    }
  } catch(_) {}
})();
// ═══ End PetAgent:pet ═══